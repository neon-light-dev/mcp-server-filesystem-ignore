{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "rootDir": ".",
    "outDir": "./dist",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "declaration": true,
    "sourceMap": true,
    "types": [
      "node",
      "vitest/globals"
    ]
  },
  "include": [
    "./**/*.ts"
  ],
  "exclude": [
    "dist",
    "coverage",
    "**/__tests__/**",
    "vitest.config.ts"
  ]
}
